{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)\\.jsx",
      "headers": [
        { "key": "Content-Type", "value": "text/babel; charset=utf-8" }
      ]
    },
    {
      "source": "/(.*)\\.glb",
      "headers": [
        { "key": "Content-Type", "value": "model/gltf-binary" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
